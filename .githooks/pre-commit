#!/bin/sh

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -ExecutionPolicy Bypass -File "./scripts/check-staged-secrets.ps1"
fi

if command -v powershell >/dev/null 2>&1; then
  exec powershell -NoProfile -ExecutionPolicy Bypass -File "./scripts/check-staged-secrets.ps1"
fi

echo "pre-commit: PowerShell was not found, so the staged secret scan could not run." >&2
exit 1
